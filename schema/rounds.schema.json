{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/symmetric_primitives/rounds.schema.json",
  "title": "Round Catalogue",
  "type": "object",
  "required": ["version", "rounds"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "rounds": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/round" }
    }
  },
  "$defs": {
    "round": {
      "type": "object",
      "required": ["id", "name", "kind", "spec"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["full_round", "half_round", "quarterround", "step", "other"]
        },
        "spec": { "type": "object" },
        "notes": { "type": "string" }
      }
    }
  }
}