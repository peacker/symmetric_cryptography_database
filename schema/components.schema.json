{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/symmetric_primitives/components.schema.json",
  "title": "Cryptographic Component Catalogue",
  "type": "object",
  "required": ["version", "components"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/component" }
    }
  },
  "$defs": {
    "parameter_def": {
      "type": "object",
      "required": ["name", "description", "type"],
      "additionalProperties": false,
      "properties": {
        "name":        { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["integer", "string", "boolean"]
        }
      }
    },
    "component": {
      "type": "object",
      "required": ["id", "name", "category"],
      "additionalProperties": false,
      "properties": {
        "id":   { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": [
            "logical",
            "register",
            "substitution",
            "permutation",
            "linear_layer",
            "shift_rotation",
            "arithmetic",
            "constant"
          ]
        },
        "special_case_of": { "type": "string", "minLength": 1 },
        "parameters": {
          "type": "array",
          "items": { "$ref": "#/$defs/parameter_def" }
        },
        "notes": { "type": "string" }
      }
    }
  }
}
