{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.org/symmetric_primitives/families.schema.json",
    "title": "Symmetric Primitive Families",
    "type": "object",
    "required": [
        "version",
        "families"
    ],
    "properties": {
        "version": {
            "type": "integer",
            "minimum": 1
        },
        "families": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/family"
            }
        }
    },
    "$defs": {
        "influence": {
            "type": "object",
            "required": [
                "source_family_id",
                "relations",
                "note"
            ],
            "properties": {
                "source_family_id": {
                    "type": "string",
                    "minLength": 1
                },
                "relations": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                        "type": "string",
                        "enum": [
                            "selection_of_possible_configurations",
                            "same_sbox",
                            "same_sbox_size",
                            "same_key_schedule",
                            "same_state_layout",
                            "same_bit_based_permutation_layer",
                            "similar_bit_based_permutation_layer",
                            "same_mix_column",
                            "similar_mix_column",
                            "same_shift_row",
                            "similar_shift_row",
                            "same_round_function",
                            "same_round_constants",
                            "improved_diffusion",
                            "inherits_alpha_reflexivity_structure",
                            "inspired_by",
                            "improvement_of",
                            "variant_of",
                            "generalization_of",
                            "related_to"
                        ]
                    }
                },
                "innovative_idea_ids": {
                    "type": "array",
                    "uniqueItems": true,
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "note": {
                    "type": "string",
                    "minLength": 1
                }
            },
            "additionalProperties": false
        },
        "component_ref": {
            "type": "object",
            "required": [
                "id"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string",
                    "minLength": 1
                },
                "params": {
                    "type": "object"
                }
            }
        },
        "construction_id": {
            "type": "string",
            "minLength": 1
        },
        "innovative_idea": {
            "type": "object",
            "required": [
                "id",
                "name"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "minLength": 1
                },
                "name": {
                    "type": "string",
                    "minLength": 1
                },
                "note": {
                    "type": "string"
                }
            },
            "additionalProperties": false
        },
        "round_id": {
            "type": "string",
            "minLength": 1
        },
        "characteristics": {
            "type": "object",
            "required": [
                "components"
            ],
            "properties": {
                "block_size_bits": {
                    "type": "integer",
                    "minimum": 1
                },
                "state_size_bits": {
                    "type": "integer",
                    "minimum": 1
                },
                "components": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/component_ref"
                    }
                }
            },
            "additionalProperties": true
        },
        "family": {
            "type": "object",
            "required": [
                "id",
                "name",
                "construction_ids",
                "round_ids",
                "target_applications",
                "characteristics",
                "reference_ids",
                "process_ids",
                "influences"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "minLength": 1
                },
                "name": {
                    "type": "string",
                    "minLength": 1
                },
                "construction_ids": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/construction_id"
                    }
                },
                "round_ids": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/round_id"
                    }
                },
                "target_applications": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "characteristics": {
                    "$ref": "#/$defs/characteristics"
                },
                "innovative_ideas": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/innovative_idea"
                    }
                },
                "reference_ids": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "process_ids": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "influences": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/influence"
                    }
                },
                "notes": {
                    "type": "string"
                }
            },
            "additionalProperties": false
        }
    },
    "additionalProperties": false
}