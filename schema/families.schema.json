{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.org/symmetric_primitives/families.schema.json",
    "title": "Symmetric Primitive Families",
    "type": "object",
    "required": [
        "version",
        "families"
    ],
    "properties": {
        "version": {
            "type": "integer",
            "minimum": 1
        },
        "families": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/family"
            }
        }
    },
    "$defs": {
        "influence": {
            "type": "object",
            "required": [
                "source_family_id",
                "relation",
                "note"
            ],
            "properties": {
                "source_family_id": {
                    "type": "string",
                    "minLength": 1
                },
                "relation": {
                    "type": "string",
                    "enum": [
                        "special_case_of",
                        "improvement_of",
                        "inspired_by",
                        "variant_of",
                        "generalization_of",
                        "related_to"
                    ]
                },
                "note": {
                    "type": "string",
                    "minLength": 1
                }
            },
            "additionalProperties": false
        },
        "component_ref": {
            "type": "object",
            "required": [
                "id"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string",
                    "minLength": 1
                },
                "params": {
                    "type": "object"
                }
            }
        },
        "construction_id": {
            "type": "string",
            "minLength": 1
        },
        "round_id": {
            "type": "string",
            "minLength": 1
        },
        "characteristics": {
            "type": "object",
            "required": [
                "components"
            ],
            "properties": {
                "block_size_bits": {
                    "type": "integer",
                    "minimum": 1
                },
                "state_size_bits": {
                    "type": "integer",
                    "minimum": 1
                },
                "components": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/component_ref"
                    }
                }
            },
            "additionalProperties": true
        },
        "family": {
            "type": "object",
            "required": [
                "id",
                "name",
                "year",
                "construction_ids",
                "round_ids",
                "target_applications",
                "characteristics",
                "publication_ids",
                "standard_ids",
                "process_ids",
                "influences"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "minLength": 1
                },
                "name": {
                    "type": "string",
                    "minLength": 1
                },
                "year": {
                    "type": "integer",
                    "minimum": 1900,
                    "maximum": 2100
                },
                "construction_ids": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/construction_id"
                    }
                },
                "round_ids": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/round_id"
                    }
                },
                "target_applications": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "characteristics": {
                    "$ref": "#/$defs/characteristics"
                },
                "publication_ids": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "standard_ids": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "process_ids": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "influences": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/influence"
                    }
                },
                "notes": {
                    "type": "string"
                }
            },
            "additionalProperties": false
        }
    },
    "additionalProperties": false
}