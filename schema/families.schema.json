{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/symmetric_primitives/families.schema.json",
  "title": "Symmetric Primitive Families",
  "type": "object",
  "required": ["version", "families"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "families": {
      "type": "array",
      "items": { "$ref": "#/$defs/family" }
    }
  },
  "$defs": {
    "influence": {
      "type": "object",
      "required": ["source_family_id", "relation", "note"],
      "properties": {
        "source_family_id": { "type": "string", "minLength": 1 },
        "relation": {
          "type": "string",
          "enum": [
            "special_case_of",
            "improvement_of",
            "inspired_by",
            "variant_of",
            "generalization_of",
            "related_to"
          ]
        },
        "note": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "characteristics": {
      "type": "object",
      "required": ["operations", "components"],
      "properties": {
        "block_size_bits":         { "type": "integer", "minimum": 1 },
        "block_size_bits_options": { "type": "array", "items": { "type": "integer", "minimum": 1 } },
        "state_size_bits":         { "type": "integer", "minimum": 1 },
        "key_size_bits_options":   { "type": "array", "items": { "type": "integer", "minimum": 1 } },
        "rounds_options":          { "type": "array", "items": { "type": "integer", "minimum": 1 } },
        "operations":  { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "components":  { "type": "array", "items": { "type": "string", "minLength": 1 } }
      },
      "additionalProperties": true
    },
    "family": {
      "type": "object",
      "required": [
        "id", "name", "year", "primitive_type",
        "target_applications", "characteristics",
        "publication_ids", "standard_ids", "process_ids", "influences"
      ],
      "properties": {
        "id":   { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "year": { "type": "integer", "minimum": 1900, "maximum": 2100 },
        "primitive_type": {
          "type": "string",
          "enum": [
            "block_cipher",
            "tweakable_block_cipher",
            "permutation",
            "compression_function",
            "update_function"
          ]
        },
        "target_applications": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "characteristics": { "$ref": "#/$defs/characteristics" },
        "publication_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "standard_ids":    { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "process_ids":     { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "influences": {
          "type": "array",
          "items": { "$ref": "#/$defs/influence" }
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
