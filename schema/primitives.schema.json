{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.org/symmetric_primitives/primitives.schema.json",
    "title": "Symmetric Primitive Instances",
    "type": "object",
    "required": [
        "version",
        "primitives"
    ],
    "properties": {
        "version": {
            "type": "integer",
            "minimum": 1
        },
        "primitives": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/primitive"
            }
        }
    },
    "$defs": {
        "characteristics": {
            "type": "object",
            "required": ["fixed_input_bits", "fixed_output_bits"],
            "properties": {
                "block_size_bits":   { "type": "integer", "minimum": 1 },
                "state_size_bits":   { "type": "integer", "minimum": 1 },
                "key_size_bits":     { "type": "integer", "minimum": 1 },
                "rounds":            { "type": "integer", "minimum": 1 },
                "fixed_input_bits":  { "type": "integer", "minimum": 1 },
                "fixed_output_bits": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": true
        },
        "primitive": {
            "type": "object",
            "required": ["id", "name", "family_id", "year", "characteristics", "standard_ids"],
            "properties": {
                "id":        { "type": "string", "minLength": 1 },
                "name":      { "type": "string", "minLength": 1 },
                "family_id": { "type": "string", "minLength": 1 },
                "year":      { "type": "integer", "minimum": 1900, "maximum": 2100 },
                "characteristics": { "$ref": "#/$defs/characteristics" },
                "standard_ids": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                },
                "notes": { "type": "string" }
            },
            "additionalProperties": false
        }
    },
    "additionalProperties": false
}