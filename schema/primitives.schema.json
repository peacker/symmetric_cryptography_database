{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.org/symmetric_primitives/primitives.schema.json",
    "title": "Symmetric Primitive Instances",
    "type": "object",
    "required": [
        "version",
        "primitives"
    ],
    "properties": {
        "version": {
            "type": "integer",
            "minimum": 1
        },
        "primitives": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/primitive"
            }
        }
    },
    "$defs": {
        "characteristics": {
            "type": "object",
            "properties": {
                "block_size_bits": {
                    "type": "integer",
                    "minimum": 1
                },
                "block_size_bits_min": {
                    "type": "integer",
                    "minimum": 1
                },
                "block_size_bits_max": {
                    "type": "integer",
                    "minimum": 1
                },
                "state_size_bits": {
                    "type": "integer",
                    "minimum": 1
                },
                "state_size_bits_min": {
                    "type": "integer",
                    "minimum": 1
                },
                "state_size_bits_max": {
                    "type": "integer",
                    "minimum": 1
                },
                "key_size_bits": {
                    "type": "integer",
                    "minimum": 1
                },
                "key_size_bits_min": {
                    "type": "integer",
                    "minimum": 1
                },
                "key_size_bits_max": {
                    "type": "integer",
                    "minimum": 1
                },
                "tweak_size_bits": {
                    "type": "integer",
                    "minimum": 1
                },
                "tweak_size_bits_min": {
                    "type": "integer",
                    "minimum": 1
                },
                "tweak_size_bits_max": {
                    "type": "integer",
                    "minimum": 1
                },
                "tweakey_size_bits": {
                    "oneOf": [
                        {
                            "type": "integer",
                            "minimum": 1
                        },
                        {
                            "type": "string",
                            "pattern": "^[1-9][0-9]*\\s*-\\s*key_size_bits$"
                        }
                    ]
                },
                "tweakey_size_bits_min": {
                    "type": "integer",
                    "minimum": 1
                },
                "tweakey_size_bits_max": {
                    "type": "integer",
                    "minimum": 1
                },
                "iv_size_bits": {
                    "type": "integer",
                    "minimum": 1
                },
                "iv_size_bits_min": {
                    "type": "integer",
                    "minimum": 1
                },
                "iv_size_bits_max": {
                    "type": "integer",
                    "minimum": 1
                },
                "nonce_size_bits": {
                    "type": "integer",
                    "minimum": 0
                },
                "nonce_size_bits_min": {
                    "type": "integer",
                    "minimum": 1
                },
                "nonce_size_bits_max": {
                    "type": "integer",
                    "minimum": 1
                },
                "rounds": {
                    "type": "integer",
                    "minimum": 1
                },
                "rounds_min": {
                    "type": "integer",
                    "minimum": 1
                },
                "rounds_max": {
                    "type": "integer",
                    "minimum": 1
                },
                "output_size_bits": {
                    "type": "integer",
                    "minimum": 1
                },
                "output_size_bits_min": {
                    "type": "integer",
                    "minimum": 1
                },
                "output_size_bits_max": {
                    "type": "integer",
                    "minimum": 1
                }
            },
            "additionalProperties": true
        },
        "primitive": {
            "type": "object",
            "required": [
                "id",
                "name",
                "family_id",
                "primitive_type",
                "characteristics"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "minLength": 1
                },
                "name": {
                    "type": "string",
                    "minLength": 1
                },
                "family_id": {
                    "type": "string",
                    "minLength": 1
                },
                "primitive_type": {
                    "type": "string",
                    "minLength": 1
                },
                "reference_ids": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "characteristics": {
                    "$ref": "#/$defs/characteristics"
                },
                "notes": {
                    "type": "string"
                }
            },
            "if": {
                "properties": {
                    "primitive_type": {
                        "enum": ["block_cipher", "tweakable_block_cipher"]
                    }
                },
                "required": ["primitive_type"]
            },
            "then": {
                "properties": {
                    "characteristics": {
                        "required": ["block_size_bits", "output_size_bits"]
                    }
                }
            },
            "additionalProperties": false
        }
    },
    "additionalProperties": false
}