{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.org/symmetric_primitives/processes.schema.json",
    "title": "Standardization Processes",
    "type": "object",
    "required": ["version", "processes"],
    "properties": {
        "version": {
            "type": "integer",
            "minimum": 1
        },
        "processes": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/process"
            }
        }
    },
    "$defs": {
        "participant": {
            "type": "object",
            "properties": {
                "family_id": {
                    "type": "string",
                    "minLength": 1
                },
                "name": {
                    "type": "string",
                    "minLength": 1
                },
                "note": {
                    "type": "string"
                }
            },
            "additionalProperties": false
        },
        "stage": {
            "type": "object",
            "required": ["id", "label"],
            "properties": {
                "id": {
                    "type": "string",
                    "minLength": 1
                },
                "label": {
                    "type": "string",
                    "minLength": 1
                },
                "kind": {
                    "type": "string",
                    "enum": ["round", "phase", "list", "category", "portfolio", "outcome", "other"]
                },
                "parent_stage_id": {
                    "type": "string",
                    "minLength": 1
                },
                "participants": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/participant"
                    }
                }
            },
            "additionalProperties": false
        },
        "process": {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
                "id": {
                    "type": "string",
                    "minLength": 1
                },
                "name": {
                    "type": "string",
                    "minLength": 1
                },
                "organizer": {
                    "type": "string"
                },
                "start_year": {
                    "type": "integer"
                },
                "end_year": {
                    "type": "integer"
                },
                "url": {
                    "type": "string"
                },
                "notes": {
                    "type": "string"
                },
                "stages": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/stage"
                    }
                }
            },
            "additionalProperties": false
        }
    },
    "additionalProperties": false
}
