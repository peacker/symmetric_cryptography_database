{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/symmetric_primitives/constructions.schema.json",
  "title": "Cryptographic Construction Catalogue",
  "type": "object",
  "required": ["version", "constructions"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "constructions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/construction" }
    }
  },
  "$defs": {
    "construction": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "abbreviation": { "type": "string", "minLength": 1 },
        "special_case_of": { "type": "string", "minLength": 1 },
        "typical_primitive_types": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "placeholder_family_names": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "notes": { "type": "string" }
      }
    }
  }
}